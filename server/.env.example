# Database connection
# For local: postgresql://user:password@localhost:5432/Trai-main
# For Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
#   For transaction pooler (Edge Functions/serverless): use port 6543 instead of 5432
DATABASE_URL="postgresql://user:password@localhost:5432/Trai-main"

# JWT — MUST change in production! Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# MinerU API
MINERU_API_URL="https://mineru.net/api/v4/extract/task"
MINERU_API_TOKEN=""

# AI (optional — can also be configured via UI in ai_model_configs table)
AI_PROVIDER=""
AI_MODEL_NAME=""
AI_API_KEY=""
AI_BASE_URL=""
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096
