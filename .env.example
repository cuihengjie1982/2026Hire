# Supabase configuration (required for production)
VITE_SUPABASE_URL="https://<your-project>.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Gemini AI API key (optional, for client-side AI features)
VITE_GEMINI_API_KEY=""

# MinerU resume parsing API token (optional, for client-side PDF parsing)
VITE_MINERU_API_TOKEN=""

# VITE_USE_MOCK_API: "true" for mock data (no backend), "false" for real Supabase
VITE_USE_MOCK_API="false"

# Legacy API base URL (kept for backward compatibility during migration)
VITE_API_BASE_URL="http://localhost:4000"

# Sentry DSN for production error tracking (optional, leave empty to disable)
VITE_SENTRY_DSN=""
